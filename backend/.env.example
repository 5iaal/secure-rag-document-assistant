# =========================
# App
# =========================
ENVIRONMENT=development
FRONTEND_URL=https://localhost

# =========================
# Database
# =========================
POSTGRES_DB=secure_rag_db
POSTGRES_USER=secure_user
POSTGRES_PASSWORD=change_me_secure_password
DATABASE_URL=postgresql://secure_user:change_me_secure_password@postgres:5432/secure_rag_db

# =========================
# JWT
# =========================
JWT_SECRET=change_me_super_secret_jwt_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =========================
# Encryption
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =========================
FERNET_KEY=change_me_generated_fernet_key

# =========================
# Internal Service Security
# =========================
INTERNAL_API_KEY=change_me_internal_api_key

# =========================
# RabbitMQ
# =========================
RABBITMQ_DEFAULT_USER=secure_rabbit_user
RABBITMQ_DEFAULT_PASS=change_me_rabbit_password
RABBITMQ_URL=amqp://secure_rabbit_user:change_me_rabbit_password@rabbitmq:5672/

# =========================
# ChromaDB
# =========================
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=secure_documents

# =========================
# Ollama
# =========================
OLLAMA_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# =========================
# OAuth - Google
# =========================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://localhost/api/auth/google/callback

# =========================
# OAuth - GitHub
# =========================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://localhost/api/auth/github/callback

# =========================
# Upload Limits
# =========================
MAX_FILE_SIZE_MB=10